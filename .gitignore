.venv/
venv/
env/
.python-version

# IDE / editor
.vscode/
.idea/
*.swp

# Datasets and reference material — too large to version
Dataset/
Updated_Dataset/
Lecture_Slides/
*.zip

# Editor/scratch backups & per-user vault state
*.bak
*.bak2
.Rhistory
.obsidian/

